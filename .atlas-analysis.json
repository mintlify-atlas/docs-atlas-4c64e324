  "keyFeatures": [
    "Direct music injection into iOS native media library (MP3, M4A, FLAC, WAV)",
    "No computer required after initial pairing file setup",
    "iOS 26.4+ RP Pairing tunnel support",
    "Auto-fetch metadata from Apple Music, iTunes, and Deezer",
    "Built-in music downloader with Apple Music search",
    "Lyrics fetching from LRCLIB, Musixmatch, and NetEase",
    "Full library backup and restore with database snapshots",
    "Playlist creation and management",
    "iOS 26.4+ artwork color repair and display support",
    "Ringtone injection (M4R)"
  ],
  "publicApiSurface": [
    "DeviceManager.shared — singleton for device connection management",
    "DeviceManager.importPairingFile(from:) — import a pairing or RP pairing file",
    "DeviceManager.startHeartbeat(forceReconnect:completion:) — establish device connection",
    "DeviceManager.injectSongs(songs:progress:completion:) — inject audio files into media library",
    "DeviceManager.injectRingtones(ringtones:progress:completion:) — inject ringtone files",
    "DeviceManager.createDatabaseSnapshot(progress:completion:) — create a library backup",
    "DeviceManager.restoreLatestDatabaseSnapshot(progress:completion:) — restore from backup",
    "DeviceManager.deleteMediaLibrary(completion:) — wipe the iOS media library database",
    "MediaLibraryBuilder.createDatabase(songs:version:playlistName:) — generate SQLite media database",
    "MediaLibraryBuilder.addSongsToExistingDatabase(existingDbData:newSongs:...) — merge songs into existing DB",
    "SongMetadata.fromURL(_:includeArtwork:) — extract metadata from a local audio file",
    "SongMetadata.fetchLyrics(title:artist:album:durationMs:) — fetch lyrics with fallback chain",
    "AppUpdateChecker.checkForUpdate() — check GitHub releases for a newer version"
  ]
